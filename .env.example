# Lokaal — dev (npm run config:local, db:push, db:seed)
DEV_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
DEV_SUPABASE_ANON_KEY=your_dev_anon_key
SUPABASE_DB_URL=postgresql://postgres.YOUR_DEV_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Production database (alleen npm run db:push:prod — NOOIT db:seed op prod)
PROD_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
PROD_SUPABASE_ANON_KEY=your_prod_anon_key
PROD_SUPABASE_DB_URL=postgresql://postgres.YOUR_PROD_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Vercel zet PROD_* en DEV_* in het dashboard (geen DB URLs nodig op Vercel)
